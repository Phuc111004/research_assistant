# Copy to .env and fill in real values (never commit .env).

# Server
HOST=0.0.0.0
PORT=8001

# LLM (OpenAI-compatible)
VLLM_API_URL=https://api.openai.com/v1
VLLM_API_KEY=
VLLM_MODEL=gpt-4o-mini

# Embeddings
EMBEDDING_API_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Reranker (optional)
RERANKER_API_URL=
RERANKER_API_KEY=
RERANKER_MODEL=rerank

# Qdrant (use host "qdrant" inside Docker Compose)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=research_papers

# Retrieval
TOP_K=3
